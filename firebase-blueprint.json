{
  "entities": {
    "FarmingPlan": {
      "title": "Farming Plan",
      "description": "A generated farming plan for a specific land and soil condition.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who created the plan." },
        "landSize": { "type": "number", "description": "Land size in acres." },
        "location": { "type": "string", "description": "Location coordinates or city name." },
        "soilType": { "type": "string", "description": "Type of soil." },
        "pH": { "type": "number", "description": "Soil pH level." },
        "waterAvailability": { "type": "string", "description": "Water availability level (Low/Medium/High)." },
        "riskPreference": { "type": "string", "description": "User's risk preference (Low/Medium/High)." },
        "droneView": { "type": "string", "description": "Base64 encoded image of the land (optional)." },
        "recommendation": {
          "type": "object",
          "properties": {
            "crops": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "cropName": { "type": "string" },
                  "allocationPercentage": { "type": "number" },
                  "duration": { "type": "string" },
                  "expectedYield": { "type": "string" },
                  "profitEstimate": { "type": "string" },
                  "riskScore": { "type": "number" },
                  "reasoning": { "type": "string" }
                }
              }
            },
            "overallRisk": { "type": "string" },
            "totalExpectedProfit": { "type": "string" },
            "summary": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the plan was created." }
      },
      "required": ["userId", "landSize", "location", "soilType", "waterAvailability", "riskPreference", "recommendation", "createdAt"]
    }
  },
  "firestore": {
    "/plans/{planId}": {
      "schema": "FarmingPlan",
      "description": "Collection of farming plans generated by users."
    }
  }
}
